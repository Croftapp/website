# Neon Postgres connection string (required for waitlist signups).
# Use the POOLER string (host contains "-pooler"). Set this in your host's
# env-var settings (Vercel) — never commit the real value.
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/neondb?sslmode=require

# Resend API key for the welcome email (https://resend.com). Without it,
# signups still succeed — the welcome email is simply skipped.
RESEND_API_KEY=

# Sender identity for the welcome email. Domain must be VERIFIED in Resend —
# use the verified subdomain (e.g. mail.croft.fi), not the bare root domain.
EMAIL_FROM=Croft <info@mail.croft.fi>

# Where replies go / what recipients see as the reply address. Any address;
# does not need to be verified. Defaults to info@croft.fi.
EMAIL_REPLY_TO=info@croft.fi

# Random string used to salt the hashed signup IP (privacy). Any long secret.
IP_SALT=

# Base URL of the live site — used for links in transactional emails
# (e.g. the unsubscribe link). No trailing slash.
SITE_URL=https://croft.fi
